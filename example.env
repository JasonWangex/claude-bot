# --- 日志配置 ---
# 日志文件路径（默认 logs/discord.log，相对于运行目录）
# LOG_FILE=logs/discord.log

# --- Discord Bot ---
CLAUDE_HOOK_ENABLED=true
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
BOT_ACCESS_TOKEN=
AUTHORIZED_GUILD_ID=
GENERAL_CHANNEL_ID=
# 通知 mention 目标用户 ID（配置后用 <@userId> 替代 @everyone，确保侧边栏红点）
# DISCORD_NOTIFY_USER_ID=
# Goal Pipeline 日志频道（可选：配置后 pipeline 执行日志单独输出到此频道）
GOAL_LOG_CHANNEL_ID=
DEFAULT_WORK_DIR=/home/user/assistant
PROJECTS_ROOT=/home/user/projects
WORKTREES_DIR=/home/user/projects/worktrees

# Claude CLI 配置
# 命令执行超时（毫秒）- 1小时
COMMAND_TIMEOUT=3600000
# 最大执行轮次 - 500 轮支持超大型复杂任务
MAX_TURNS=500

# DeepSeek API（用于轻量 LLM 任务：分支名生成等）
DEEPSEEK_API_KEY=

# 本地 HTTP API 端口（设为 0 禁用）
API_PORT=3456
# API 监听地址（默认 127.0.0.1，设为 0.0.0.0 可接受 Tailscale 等远程连接）
# 本地请求免鉴权，远程请求需要 BOT_ACCESS_TOKEN
# API_LISTEN=0.0.0.0
# Web UI 地址（可选，配置后 Done 消息会附带 changes 查看链接）
# WEB_URL=http://your-server:3457

# 部署时间（由 deploy.sh 自动写入）
# DEPLOY_TIME=2025-01-01T00:00:00Z

# --- 进程监控配置 ---
# 进程检查间隔（毫秒）- 默认 5 秒
MONITOR_CHECK_INTERVAL=5000
# 通知冷却期（毫秒）- 默认 3 分钟
MONITOR_COOLDOWN=180000
# 最小运行时间阈值（秒）- 低于此值视为异常退出，默认 2 秒
MONITOR_MIN_RUNTIME=2
# 最大运行时间阈值（秒）- 超过此值视为超时，默认 3600 秒（1小时）
MONITOR_MAX_RUNTIME=3600
# 要监控的服务列表（逗号分隔）- 默认只监控 claude-discord
MONITOR_SERVICES=claude-discord

# --- Aliyun OSS（可选：配置后文件上传到 OSS 并发送签名链接，不配置则使用附件方式）---
# OSS_REGION=oss-cn-hangzhou
# OSS_BUCKET=my-bot-files
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_ENDPOINT=
