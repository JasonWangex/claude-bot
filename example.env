# =============================================================================
# Claude Discord Bot — Environment Variables
# Copy this file to .env and fill in your values.
# Run ./config.sh for an interactive setup wizard.
# =============================================================================

# --- Discord Bot (Required) ---
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
BOT_ACCESS_TOKEN=

# --- Discord IDs (auto-filled by /login, or set manually) ---
AUTHORIZED_GUILD_ID=
GENERAL_CHANNEL_ID=

# --- Optional Discord channels & users ---
# Goal Pipeline 日志专用频道（配置后 pipeline 执行日志单独输出）
GOAL_LOG_CHANNEL_ID=
# 通知 @mention 目标用户 ID（替代 @everyone，确保侧边栏红点）
# DISCORD_NOTIFY_USER_ID=

# --- Paths ---
DEFAULT_WORK_DIR=/home/user/assistant
PROJECTS_ROOT=/home/user/projects
WORKTREES_DIR=/home/user/projects/worktrees

# --- Claude CLI ---
# 命令执行超时（毫秒）— 默认 1 小时
COMMAND_TIMEOUT=3600000
# 最大执行轮次
MAX_TURNS=500
# 无输出超时（毫秒）— 默认 1 分钟
STALL_TIMEOUT=60000

# --- Claude Models (Orchestrator pipeline) ---
PIPELINE_SONNET_MODEL=claude-sonnet-4-6
PIPELINE_OPUS_MODEL=claude-opus-4-6

# --- DeepSeek API (optional: branch name / title generation) ---
# 获取: https://platform.deepseek.com/ → API Keys
DEEPSEEK_API_KEY=

# --- Local HTTP API ---
# 端口（设为 0 禁用）
API_PORT=3456
# 监听地址（默认 127.0.0.1 仅本机；设为 0.0.0.0 支持 Tailscale 远程访问）
# 远程请求需要 Authorization: Bearer <BOT_ACCESS_TOKEN>
# API_LISTEN=0.0.0.0
# Web 看板地址（可选，配置后 Done 消息附带 changes 查看链接）
# WEB_URL=http://your-server:4173

# --- Process Monitor ---
# 进程检查间隔（毫秒）
MONITOR_CHECK_INTERVAL=5000
# 通知冷却期（毫秒）
MONITOR_COOLDOWN=180000
# 最小运行时间阈值（秒）— 低于此值视为异常退出
MONITOR_MIN_RUNTIME=2
# 最大运行时间阈值（秒）— 超过此值视为超时
MONITOR_MAX_RUNTIME=3600
# 要监控的服务（逗号分隔）
MONITOR_SERVICES=claude-discord

# --- Aliyun OSS (optional: file uploads → signed URL instead of attachment) ---
# OSS_REGION=oss-cn-hangzhou
# OSS_BUCKET=my-bot-files
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_ENDPOINT=

# --- Deployment (auto-written by deploy.sh) ---
# DEPLOY_TIME=2025-01-01T00:00:00Z
