# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
BOT_ACCESS_TOKEN=
AUTHORIZED_CHAT_ID=
DEFAULT_WORK_DIR=/home/user/assistant

# Claude CLI 配置
# 命令执行超时（毫秒）- 1小时
COMMAND_TIMEOUT=3600000
# 最大执行轮次 - 500 轮支持超大型复杂任务
MAX_TURNS=500

# 本地 HTTP API 端口（设为 0 禁用）
API_PORT=3456

# 代理设置
http_proxy=http://127.0.0.1:7890
https_proxy=http://127.0.0.1:7890

# --- 进程监控配置 ---
# 进程检查间隔（毫秒）- 默认 5 秒
MONITOR_CHECK_INTERVAL=5000
# 通知冷却期（毫秒）- 默认 3 分钟
MONITOR_COOLDOWN=180000
# 最小运行时间阈值（秒）- 低于此值视为异常退出，默认 2 秒
MONITOR_MIN_RUNTIME=2
# 最大运行时间阈值（秒）- 超过此值视为超时，默认 3600 秒（1小时）
MONITOR_MAX_RUNTIME=3600
# 要监控的服务列表（逗号分隔）- 默认只监控 claude-telegram
MONITOR_SERVICES=claude-telegram
